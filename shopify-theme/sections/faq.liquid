<section id="faq" class="sc-faq">
  <div class="sc-container sc-faq-inner">
    <div class="sc-section-header">
      <p class="sc-label">Questions</p>
      <h2 class="sc-heading">Everything you'd ask before buying.</h2>
    </div>
    <div class="sc-accordion">
      {%- for block in section.blocks -%}
        <div class="sc-accordion-item" {{ block.shopify_attributes }}>
          <button class="sc-accordion-trigger" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <svg class="sc-accordion-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="sc-accordion-content">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {%- else -%}
        {%- assign default_faqs = "Is this pillow right for side and back sleepers?|Yes. The contoured geometry is specifically engineered for both, with a higher lobe to support side sleeping and a lower lobe for back sleepers.,How long until I notice a difference?|Most sleepers report improved alignment within the first 7–14 nights as the foam adapts to your contours and your body adjusts to neutral posture.,How do I care for it?|The cooling cover is removable and machine washable. The memory foam core should be spot cleaned and air dried.,Is shipping free?|Yes — free shipping on every order, with carbon-neutral delivery." | split: "," -%}
        {%- for faq in default_faqs -%}
          {%- assign parts = faq | split: "|" -%}
          <div class="sc-accordion-item">
            <button class="sc-accordion-trigger" aria-expanded="false">
              <span>{{ parts[0] }}</span>
              <svg class="sc-accordion-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="sc-accordion-content">
              <p>{{ parts[1] }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "Is this pillow right for side and back sleepers?", "answer": "Yes. The contoured geometry is specifically engineered for both, with a higher lobe to support side sleeping and a lower lobe for back sleepers." } },
        { "type": "faq_item", "settings": { "question": "How long until I notice a difference?", "answer": "Most sleepers report improved alignment within the first 7–14 nights as the foam adapts to your contours and your body adjusts to neutral posture." } },
        { "type": "faq_item", "settings": { "question": "How do I care for it?", "answer": "The cooling cover is removable and machine washable. The memory foam core should be spot cleaned and air dried." } },
        { "type": "faq_item", "settings": { "question": "Is shipping free?", "answer": "Yes — free shipping on every order, with carbon-neutral delivery." } }
      ]
    }
  ]
}
{% endschema %}
