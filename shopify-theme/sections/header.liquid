<header class="sc-header" id="SiteHeader">
  <div class="sc-container sc-header-inner">
    <a href="/" class="sc-logo">
      <span class="sc-logo-dot"></span>
      <span class="sc-logo-text">SLEEPCET</span>
    </a>

    <nav class="sc-nav" aria-label="Main navigation">
      <a href="#science" class="sc-nav-link">Science</a>
      <a href="#benefits" class="sc-nav-link">Benefits</a>
      <a href="#compare" class="sc-nav-link">Compare</a>
      <a href="#faq" class="sc-nav-link">FAQ</a>
    </nav>

    <button id="cart-toggle-btn" class="sc-cart-toggle" aria-label="Open cart">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
      </svg>
      <span id="cart-count-badge" class="sc-cart-badge" style="display:none">0</span>
    </button>
  </div>
</header>

{% schema %}
{ "name": "Header", "settings": [] }
{% endschema %}
