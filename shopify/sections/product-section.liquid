{% assign product = section.settings.product | default: all_products.first %}

<section id="product-section-{{ section.id }}" class="sleepcet-product-section">
  <div class="sleepcet-container">

    {%- if section.settings.show_heading -%}
    <div class="sleepcet-heading">
      <p class="sleepcet-label">The Pillow</p>
      <h2 class="sleepcet-title">{{ product.title }}</h2>
    </div>
    {%- endif -%}

    <div class="sleepcet-grid">

      <!-- IMAGE GALLERY -->
      <div class="sleepcet-gallery">
        <div class="sleepcet-main-image" id="MainImage-{{ section.id }}">
          <img
            src="{{ product.featured_image | image_url: width: 900 }}"
            alt="{{ product.featured_image.alt | escape }}"
            id="MainImageEl-{{ section.id }}"
            width="900"
            height="900"
            loading="lazy"
          />
        </div>

        {%- if product.images.size > 1 -%}
        <div class="sleepcet-thumbnails">
          {%- for image in product.images -%}
          <button
            class="sleepcet-thumb {% if forloop.first %}active{% endif %}"
            data-image-url="{{ image | image_url: width: 900 }}"
            data-section="{{ section.id }}"
            aria-label="{{ image.alt | escape }}"
          >
            <img src="{{ image | image_url: width: 120 }}" alt="{{ image.alt | escape }}" width="120" height="120" />
          </button>
          {%- endfor -%}
        </div>
        {%- endif -%}
      </div>

      <!-- PRODUCT INFO -->
      <div class="sleepcet-info">

        <!-- Rating -->
        <div class="sleepcet-rating">
          <span class="sleepcet-stars">★★★★★</span>
          <span class="sleepcet-review-count">4.9 · 2,400+ reviews</span>
        </div>

        <!-- Price -->
        <div class="sleepcet-price" id="ProductPrice-{{ section.id }}">
          {%- if product.compare_at_price > product.price -%}
            <span class="sleepcet-price-compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="sleepcet-price-current">{{ product.price | money }}</span>
        </div>

        <!-- Description -->
        {%- if section.settings.show_description and product.description != blank -%}
        <div class="sleepcet-description">
          {{ product.description }}
        </div>
        {%- endif -%}

        <!-- Variant form -->
        {%- form 'product', product, id: "AddToCartForm-{{ section.id }}", data-product-form: "" -%}
          <input type="hidden" name="id" id="VariantId-{{ section.id }}" value="{{ product.selected_or_first_available_variant.id }}" />

          {%- unless product.has_only_default_variant -%}
          <div class="sleepcet-variants">
            {%- for option in product.options_with_values -%}
            <div class="sleepcet-option-group">
              <p class="sleepcet-option-label">{{ option.name }}</p>
              <div class="sleepcet-option-buttons" data-option-index="{{ forloop.index0 }}">
                {%- for value in option.values -%}
                <button
                  type="button"
                  class="sleepcet-option-btn {% if option.selected_value == value %}active{% endif %}"
                  data-value="{{ value | escape }}"
                  data-option-index="{{ forloop.parentloop.index0 }}"
                  data-section="{{ section.id }}"
                >
                  {{ value }}
                </button>
                {%- endfor -%}
              </div>
            </div>
            {%- endfor -%}
          </div>
          {%- endunless -%}

          <!-- Quantity -->
          {%- if section.settings.show_quantity -%}
          <div class="sleepcet-quantity">
            <label class="sleepcet-option-label" for="Quantity-{{ section.id }}">Quantity</label>
            <div class="sleepcet-quantity-wrap">
              <button type="button" class="sleepcet-qty-btn" data-action="minus" data-section="{{ section.id }}">−</button>
              <input type="number" id="Quantity-{{ section.id }}" name="quantity" value="1" min="1" class="sleepcet-qty-input" />
              <button type="button" class="sleepcet-qty-btn" data-action="plus" data-section="{{ section.id }}">+</button>
            </div>
          </div>
          {%- endif -%}

          <!-- Add to cart button -->
          <button
            type="submit"
            id="AddToCartBtn-{{ section.id }}"
            class="sleepcet-atc-btn"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
          >
            <span id="AddToCartBtnText-{{ section.id }}">
              {%- if product.selected_or_first_available_variant.available -%}
                {{ section.settings.button_label | default: 'Add to Cart' }}
              {%- else -%}
                Sold Out
              {%- endif -%}
            </span>
            <span class="sleepcet-atc-spinner" id="AddToCartSpinner-{{ section.id }}" style="display:none;">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2" stroke-dasharray="40" stroke-dashoffset="20" style="animation:sleepcet-spin 0.8s linear infinite;transform-origin:center;"/>
              </svg>
            </span>
          </button>

        {%- endform -%}

        <!-- Trust badges -->
        <div class="sleepcet-trust">
          <div class="sleepcet-trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12H3l9-9 9 9h-2"/><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-7"/><path d="M9 21v-6a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v6"/></svg>
            <span>Free shipping</span>
          </div>
          <div class="sleepcet-trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>5-year warranty</span>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .sleepcet-product-section {
    background: #f5f0eb;
    padding: 80px 0;
    font-family: inherit;
  }
  .sleepcet-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .sleepcet-heading {
    text-align: center;
    margin-bottom: 56px;
  }
  .sleepcet-label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(58,42,28,0.6);
    margin: 0 0 8px;
  }
  .sleepcet-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 600;
    color: #3a2a1c;
    margin: 0;
  }
  .sleepcet-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .sleepcet-grid { grid-template-columns: 1fr 1fr; }
  }

  /* Gallery */
  .sleepcet-main-image {
    aspect-ratio: 1;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }
  .sleepcet-main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sleepcet-thumbnails {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    margin-top: 14px;
  }
  .sleepcet-thumb {
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    opacity: 0.55;
    cursor: pointer;
    padding: 0;
    background: none;
    transition: opacity 0.2s, border-color 0.2s;
  }
  .sleepcet-thumb:hover { opacity: 0.85; }
  .sleepcet-thumb.active { border-color: #c9a96e; opacity: 1; }
  .sleepcet-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Info */
  .sleepcet-rating {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sleepcet-stars { color: #c9a96e; font-size: 16px; letter-spacing: 2px; }
  .sleepcet-review-count { font-size: 13px; color: rgba(58,42,28,0.6); }
  .sleepcet-price {
    margin-top: 18px;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .sleepcet-price-current { font-size: 36px; font-weight: 600; color: #3a2a1c; }
  .sleepcet-price-compare { font-size: 22px; color: rgba(58,42,28,0.4); text-decoration: line-through; }
  .sleepcet-description {
    margin-top: 18px;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(58,42,28,0.7);
  }
  .sleepcet-description p { margin: 0 0 8px; }

  /* Variants */
  .sleepcet-variants { margin-top: 28px; }
  .sleepcet-option-group { margin-bottom: 18px; }
  .sleepcet-option-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(58,42,28,0.6);
    margin: 0 0 10px;
  }
  .sleepcet-option-buttons { display: flex; flex-wrap: wrap; gap: 8px; }
  .sleepcet-option-btn {
    padding: 8px 18px;
    border-radius: 999px;
    border: 1.5px solid #d9cfc5;
    background: #fff;
    font-size: 13px;
    cursor: pointer;
    color: #3a2a1c;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }
  .sleepcet-option-btn:hover { border-color: rgba(58,42,28,0.4); }
  .sleepcet-option-btn.active { border-color: #3a2a1c; background: #3a2a1c; color: #faf7f2; }
  .sleepcet-option-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Quantity */
  .sleepcet-quantity { margin-top: 22px; }
  .sleepcet-quantity-wrap {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid #d9cfc5;
    border-radius: 999px;
    overflow: hidden;
    margin-top: 8px;
  }
  .sleepcet-qty-btn {
    width: 40px; height: 40px;
    background: none; border: none;
    font-size: 18px; cursor: pointer;
    color: #3a2a1c;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  .sleepcet-qty-btn:hover { background: rgba(58,42,28,0.06); }
  .sleepcet-qty-input {
    width: 48px; text-align: center;
    border: none; border-left: 1.5px solid #d9cfc5; border-right: 1.5px solid #d9cfc5;
    height: 40px; font-size: 14px; color: #3a2a1c; outline: none;
    -moz-appearance: textfield;
  }
  .sleepcet-qty-input::-webkit-outer-spin-button,
  .sleepcet-qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

  /* ATC button */
  .sleepcet-atc-btn {
    margin-top: 32px;
    width: 100%;
    height: 56px;
    border-radius: 999px;
    border: none;
    background: #3a2a1c;
    color: #faf7f2;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background 0.2s, opacity 0.2s;
  }
  .sleepcet-atc-btn:hover { background: rgba(58,42,28,0.85); }
  .sleepcet-atc-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Trust */
  .sleepcet-trust {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 28px;
  }
  .sleepcet-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px 8px;
    border-radius: 12px;
    background: #fff;
    font-size: 12px;
    text-align: center;
    color: rgba(58,42,28,0.65);
  }
  .sleepcet-trust-item svg { color: #c9a96e; flex-shrink: 0; }

  @keyframes sleepcet-spin { to { transform: rotate(360deg); } }
</style>

<script>
(function() {
  var sectionId = {{ section.id | json }};
  var productJson = {{ product | json }};

  // Thumbnail switcher
  document.querySelectorAll('.sleepcet-thumb[data-section="{{ section.id }}"]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.sleepcet-thumb[data-section="{{ section.id }}"]').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var img = document.getElementById('MainImageEl-{{ section.id }}');
      if (img) img.src = btn.dataset.imageUrl;
    });
  });

  // Variant option buttons
  var selectedOptions = [
    {%- for option in product.options_with_values -%}
      {{ option.selected_value | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  function findVariant() {
    return productJson.variants.find(function(v) {
      return v.options.every(function(opt, i) { return opt === selectedOptions[i]; });
    });
  }

  function updatePrice(variant) {
    var priceEl = document.getElementById('ProductPrice-{{ section.id }}');
    if (!priceEl || !variant) return;
    var amount = (variant.price / 100).toFixed(2);
    var compareAmount = variant.compare_at_price ? (variant.compare_at_price / 100).toFixed(2) : null;
    var currency = {{ shop.currency | json }};
    priceEl.innerHTML = (compareAmount ? '<span class="sleepcet-price-compare">' + currency + ' ' + compareAmount + '</span>' : '') +
      '<span class="sleepcet-price-current">' + currency + ' ' + amount + '</span>';
  }

  function updateButton(variant) {
    var btn = document.getElementById('AddToCartBtn-{{ section.id }}');
    var txt = document.getElementById('AddToCartBtnText-{{ section.id }}');
    var input = document.getElementById('VariantId-{{ section.id }}');
    if (!btn || !txt || !input) return;
    if (variant && variant.available) {
      btn.disabled = false;
      txt.textContent = {{ section.settings.button_label | default: 'Add to Cart' | json }};
      input.value = variant.id;
    } else {
      btn.disabled = true;
      txt.textContent = 'Sold Out';
    }
  }

  document.querySelectorAll('.sleepcet-option-btn[data-section="{{ section.id }}"]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = parseInt(btn.dataset.optionIndex);
      selectedOptions[idx] = btn.dataset.value;
      // Update active state within same option group
      btn.closest('.sleepcet-option-buttons').querySelectorAll('.sleepcet-option-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var variant = findVariant();
      updatePrice(variant);
      updateButton(variant);
    });
  });

  // Quantity buttons
  var qtyInput = document.getElementById('Quantity-{{ section.id }}');
  document.querySelectorAll('.sleepcet-qty-btn[data-section="{{ section.id }}"]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!qtyInput) return;
      var val = parseInt(qtyInput.value) || 1;
      qtyInput.value = btn.dataset.action === 'plus' ? val + 1 : Math.max(1, val - 1);
    });
  });

  // Add to cart with AJAX
  var form = document.getElementById('AddToCartForm-{{ section.id }}');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = document.getElementById('AddToCartBtn-{{ section.id }}');
      var txt = document.getElementById('AddToCartBtnText-{{ section.id }}');
      var spinner = document.getElementById('AddToCartSpinner-{{ section.id }}');
      var variantId = document.getElementById('VariantId-{{ section.id }}').value;
      var qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;

      btn.disabled = true;
      if (txt) txt.style.display = 'none';
      if (spinner) spinner.style.display = 'flex';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.status) {
          console.error('Cart error:', data.description);
        } else {
          // Trigger cart drawer if theme supports it
          document.dispatchEvent(new CustomEvent('cart:add', { detail: { item: data } }));
          // Fallback: open cart page
          if (typeof window.Shopify !== 'undefined' && typeof window.Shopify.onCartUpdate === 'function') {
            window.Shopify.onCartUpdate();
          }
        }
      })
      .catch(function(err) { console.error('Add to cart failed:', err); })
      .finally(function() {
        btn.disabled = false;
        if (txt) txt.style.display = '';
        if (spinner) spinner.style.display = 'none';
      });
    });
  }
})();
</script>

{% schema %}
{
  "name": "Product Section",
  "tag": "section",
  "class": "sleepcet-product-section-wrapper",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show section heading",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show product description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": false
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button text",
      "default": "Add to Cart"
    }
  ],
  "presets": [
    {
      "name": "Product Section",
      "category": "Product"
    }
  ]
}
{% endschema %}
